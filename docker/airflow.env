# ============================================================================
# Airflow environment — shared by airflow-init, airflow-scheduler,
# airflow-webserver, and dbt services
# ============================================================================

# Airflow metadata database (separate DB on the same Postgres instance)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/airflow

# Use LocalExecutor (single-machine, no Celery needed)
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Disable example DAGs
AIRFLOW__CORE__LOAD_EXAMPLES=False

# DAGs folder (mounted from host)
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/airflow/dags


# Webserver
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True
AIRFLOW__WEBSERVER__RELOAD_ON_SIGTERM=True

# Fernet key for encrypting connections (generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Using a static key here for local dev — change for production!)
AIRFLOW__CORE__FERNET_KEY=uXjvlqfKvBk6HJRW5E1KK8tJ3J2P1iXA9hCLWFJdMxs=

# Stock data connection string (used by DAG tasks)
POSTGRES_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/stocks

# DuckDB path inside container
DUCKDB_PATH=/opt/airflow/data/app.duckdb

# dbt profiles directory
DBT_PROFILES_DIR=/opt/airflow/dbt

# Logging
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
