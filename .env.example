# ============================================================================
# de-bootcamp-summer2026 Environment Configuration
# Copy this file to .env and update values for your environment
# ============================================================================

# App Configuration
APP_NAME=de-bootcamp-summer2026
APP_ENV=development

# Phase 1: Streamlit & Local Data
DUCKDB_PATH=data/app.duckdb
LOG_LEVEL=INFO

# Phase 2: PostgreSQL (optional, for Airflow + app)
# If POSTGRES_URL is not set, app uses DuckDB only
# POSTGRES_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/stocks

# Airflow (Phase 2+)
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__DAGS_FOLDER=./airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///./airflow/airflow.db

# Phase 3: dbt
DBT_PROFILES_DIR=./dbt

# Phase 5: Ollama (optional, for LLM/RAG)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# yfinance Configuration
YFINANCE_INTERVAL=5m
YFINANCE_PERIOD=5d
YFINANCE_WARMUP_PERIOD=60d

REDIS_HOST=localhost
REDIS_PORT=6379
